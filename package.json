{
  "name": "mood-music-player",
  "version": "1.0.0",
  "main": "electron.js",
  "scripts": {
    "dev": "vite",
    "start": "concurrently \"npm run dev\" \"npm run electron\"",
    "electron": "wait-on http://localhost:5173 && .\\node_modules\\.electron\\dist\\electron.exe .",
    "build": "vite build",
    "preview": "vite preview",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "dotenv": "^17.3.1",
    "howler": "^2.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-player": "^3.4.0",
    "serve-handler": "^6.1.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^6.0.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.moodmusic.player",
    "productName": "Cadence",
    "files": [
      "dist/**/*",
      "electron.js",
      "preload.js",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
